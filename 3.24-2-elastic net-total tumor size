# ==========================================
# 1. 强制数值化防爆雷 (确保全是干净的数字)
class(X_raw) <- "numeric"
class(Y_transformed) <- "numeric"
X <- X_raw[common_samples, ]
Y <- Y_transformed[common_samples]
# 2. 超参数网格寻优与交叉验证
set.seed(2026) # 锁定随机种子，结果可重复
alphas <- seq(0.1, 0.9, by = 0.1)
cv_results <- list()
min_cv_errors <- numeric(length(alphas))
# 🌟 智能调整折数：样本量16个，采用稳健的 5 折交叉验证 (nfolds=5)
cat("\n⏳ 正在启动弹性网络建模 (自动采用 5-fold CV，并执行内部标准化)...\n")
for (i in seq_along(alphas)) {
  # family="gaussian" 处理连续数值，standardize=TRUE 内部抹平量纲差异
  fit <- cv.glmnet(X, Y, family = "gaussian", alpha = alphas[i], nfolds = 5, standardize = TRUE)
  cv_results[[i]] <- fit
  min_cv_errors[i] <- min(fit$cvm)
}
# 3. 锁定最优模型
best_alpha_index <- which.min(min_cv_errors)
best_alpha <- alphas[best_alpha_index]
best_cv_model <- cv_results[[best_alpha_index]]
cat("🎯 寻优结束！你的数据最适合的 Alpha 值为:", best_alpha, "\n")
# 4. 提取终极 Biomarker Panel (顶刊推荐的 lambda.1se 极简模型)
best_lambda <- best_cv_model$lambda.1se
coef_matrix <- coef(best_cv_model, s = best_lambda)
# 提取特征系数
active_features <- rownames(coef_matrix)[which(coef_matrix[, 1] != 0)]
active_coefficients <- coef_matrix[which(coef_matrix[, 1] != 0), 1]
# 5. 打印最终战果
if(length(active_features) <= 1) {
  cat("⚠️ 模型经过最严苛的惩罚后，没有特征存活。你可以把上面代码里的 best_lambda 改成 best_cv_model$lambda.min 再试一次。\n")
} else {
  biomarker_panel <- data.frame(Feature = active_features, Coefficient = active_coefficients)
  biomarker_panel <- biomarker_panel[biomarker_panel$Feature != "(Intercept)", ]
  biomarker_panel <- biomarker_panel[order(abs(biomarker_panel$Coefficient), decreasing = TRUE), ]
  cat("\n🏆 恭喜！极简抗癌微生态/代谢诊断面板提取完毕：\n")
  print(biomarker_panel)
}
