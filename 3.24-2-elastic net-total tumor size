best_lambda <- best_cv_model$lambda.1se
# 2. 让模型对原本的 X 矩阵进行预测，得到预测的 Y 值 (Y_pred)
# 注意：此时的 Y 和 Y_pred 都是经过 log2 转换的数值
Y_pred <- predict(best_cv_model, newx = X, s = best_lambda)
# 3. 计算 RMSE (均方根误差)
# 残差 (真实值 - 预测值)
residuals <- Y - Y_pred
MSE <- mean(residuals^2)
RMSE <- sqrt(MSE)
# 4. 计算 R-squared (决定系数)
# R2 = 1 - (残差平方和 / 总平方和)
SST <- sum((Y - mean(Y))^2) # Total Sum of Squares
SSR <- sum(residuals^2) # Residual Sum of Squares
R_squared <- 1 - (SSR / SST)
# 5. 在控制台打印出极其漂亮的战报
